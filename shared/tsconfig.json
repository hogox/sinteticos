{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "declaration": true,
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "files": [
    "./utils.ts",
    "./screen-svg.ts",
    "./seed-data.ts",
    "./simulation.ts",
    "./persona-chat.ts",
    "./reporting.ts"
  ]
}
