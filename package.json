{
  "name": "sinteticos-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "server": "node server.mjs",
    "web": "npm --prefix web run dev",
    "dev": "concurrently -n shared,server,web -c yellow,blue,green \"npm run shared:watch\" \"npm run server\" \"npm run web\"",
    "shared:build": "tsc -p shared",
    "shared:watch": "tsc -p shared --watch --preserveWatchOutput",
    "shared:typecheck": "tsc -p shared --noEmit",
    "web:install": "npm --prefix web install",
    "web:build": "npm run shared:build && npm --prefix web run build",
    "web:typecheck": "npm --prefix web run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "busboy": "^1.6.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "pdf-parse": "^2.4.5",
    "lighthouse": "^12.0.0",
    "playwright": "^1.55.0"
  }
}
