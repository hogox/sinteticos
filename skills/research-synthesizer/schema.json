{
  "type": "object",
  "required": ["summary", "runs_analyzed", "themes"],
  "properties": {
    "summary": { "type": "string" },
    "runs_analyzed": { "type": "integer", "minimum": 0 },
    "saturation_estimate": {
      "type": "string",
      "enum": ["saturated", "emerging", "insufficient"]
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "evidence_count", "description"],
        "properties": {
          "label": { "type": "string" },
          "evidence_count": { "type": "integer", "minimum": 0 },
          "divergence_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "description": { "type": "string" },
          "quotes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["run_id", "text"],
              "properties": {
                "run_id": { "type": "string" },
                "step": { "type": "number" },
                "text": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "divergences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "rationale"],
        "properties": {
          "label": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    },
    "outliers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label"],
        "properties": {
          "label": { "type": "string" },
          "run_id": { "type": "string" }
        }
      }
    }
  }
}
