{
  "type": "object",
  "required": ["summary", "overall_verdict", "findings"],
  "properties": {
    "summary": { "type": "string" },
    "overall_verdict": {
      "type": "string",
      "enum": ["pass", "needs-work", "fail"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "severity", "category", "detail", "recommendation"],
        "properties": {
          "label": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "category": {
            "type": "string",
            "enum": ["performance", "accessibility", "best-practices", "seo"]
          },
          "detail": { "type": "string" },
          "framework_citation": { "type": "string" },
          "recommendation": { "type": "string" }
        }
      }
    }
  }
}
